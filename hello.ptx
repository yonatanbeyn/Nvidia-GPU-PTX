//
// hello.ptx — hand-written PTX for sm_89 (Ada Lovelace)
//
// Each thread writes its threadIdx.x into out[threadIdx.x].
// Launched with 1 block of 32 threads, so out[0..31] = 0..31.
//

.version 7.8                              // PTX ISA version
.target  sm_89                            // target architecture (your RTX 4060)
.address_size 64                          // 64-bit pointers

// ----------------------------------------------------------------------------
// .visible .entry  -> a kernel callable from host code
// One parameter: a 64-bit pointer to the output array.
// ----------------------------------------------------------------------------
.visible .entry hello(
    .param .u64 hello_param_out
)
{
    .reg .b32   %tx;          // one 32-bit register for the thread index
    .reg .b64   %rd<5>;        // four 64-bit registers (%rd1..%rd4)

    // %rd1 = out  (raw pointer from the kernel parameter)
    ld.param.u64       %rd1, [hello_param_out];

    // Translate generic pointer to a .global address space pointer.
    // (params come in as generic; loads/stores into the global heap need .global.)
    cvta.to.global.u64 %rd2, %rd1;

    // %tx = threadIdx.x   (PTX builtin: %tid is the special register;
    //                      .x picks the x component of the 3D vector)
    mov.u32            %tx, %tid.x;

    // %rd3 = tid * 4         (each int is 4 bytes)
    //   mul.wide.u32 multiplies two 32-bit values into a 64-bit result.
    mul.wide.u32       %rd3, %tx, 4;

    // %rd4 = out + tid*4     (byte address of out[tid])
    add.s64            %rd4, %rd2, %rd3;

    // *((int*)%rd4) = tid
    st.global.u32      [%rd4], %tx;

    ret;
}
